<graph id="S1_GRD_Gamma0_RTC_TC">
    <version>1.0</version>

    <node id="Read">
        <operator>Read</operator>
        <parameters>
            <file>${input}</file>
        </parameters>
    </node>

    <node id="Apply-Orbit-File">
        <operator>Apply-Orbit-File</operator>
        <sources>
            <source>Read</source>
        </sources>
        <parameters>
            <orbitType>Sentinel Precise</orbitType>
            <polyDegree>3</polyDegree>
        </parameters>
    </node>

    <node id="ThermalNoiseRemoval">
        <operator>ThermalNoiseRemoval</operator>
        <sources>
            <source>Apply-Orbit-File</source>
        </sources>
        <parameters>
            <removeThermalNoise>true</removeThermalNoise>
        </parameters>
    </node>

    <node id="Calibration">
        <operator>Calibration</operator>
        <sources>
            <source>ThermalNoiseRemoval</source>
        </sources>
        <parameters>
            <outputSigmaBand>false</outputSigmaBand>
            <outputGammaBand>true</outputGammaBand>
        </parameters>
    </node>

    <node id="Terrain-Flattening">
        <operator>Terrain-Flattening</operator>
        <sources>
            <source>Calibration</source>
        </sources>
        <parameters>
            <demName>Copernicus 30m Global DEM</demName>
            <demResamplingMethod>BILINEAR_INTERPOLATION</demResamplingMethod>
            <incidenceAngleForTF>Local incidence angle from DEM</incidenceAngleForTF>
            <saveLocalIncidenceAngle>true</saveLocalIncidenceAngle>
            <saveProjectedLocalIncidenceAngle>true</saveProjectedLocalIncidenceAngle>
        </parameters>
    </node>

    <node id="Terrain-Correction">
        <operator>Terrain-Correction</operator>
        <sources>
            <source>Terrain-Flattening</source>
        </sources>
        <parameters>
            <demName>Copernicus 30m Global DEM</demName>
            <imgResamplingMethod>BILINEAR_INTERPOLATION</imgResamplingMethod>
            <pixelSpacingInMeter>10.0</pixelSpacingInMeter>
            <saveIncidenceAngleFromEllipsoid>true</saveIncidenceAngleFromEllipsoid>
        </parameters>
    </node>

    <node id="Write">
        <operator>Write</operator>
        <sources>
            <source>Terrain-Correction</source>
        </sources>
        <parameters>
            <file>${output}</file>
            <formatName>GeoTIFF</formatName>
        </parameters>
    </node>

</graph>
